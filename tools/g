                                COMPREPLY=( $(compgen -W "${local_branches} -m --message" -- "${cur}") )
                                ;;
                        esac
                        ;;
                    tag|tags)
                        case "${prev_word}" in
                            new) COMPREPLY=( $(compgen -W "patch minor major" -- "${cur}") ) ;;
                            rm|send|edit)
                                local existing_tags
                                existing_tags=$(git tag -l 2>/dev/null)
                                COMPREPLY=( $(compgen -W "${existing_tags}" -- "${cur}") )
                                ;;
                        esac
                        ;;
                    remote)
                        case "${prev_word}" in
                            new) COMPREPLY=( $(compgen -W "--name --url" -- "${cur}") ) ;;
                            rm|update)
                                local remotes
                                remotes=$(git remote 2>/dev/null)
                                COMPREPLY=( $(compgen -W "${remotes}" -- "${cur}") )
                                ;;
                        esac
                        ;;
                    conflict)
                        case "${prev_word}" in
                            resolve|diff)
                                local files
                                files=$(git diff --name-only --diff-filter=U 2>/dev/null)
                                COMPREPLY=( $(compgen -W "${files}" -- "${cur}") )
                                ;;
                        esac
                        ;;
                esac
                ;;
            4)
                if [[ "${COMP_WORDS[1]}" == "history" && "${COMP_WORDS[2]}" == "session" ]]; then
                    case "${prev_word}" in
                        new)
                            local hashes
                            hashes=$(git log --pretty=format:'%h' -n 50 2>/dev/null)
                            COMPREPLY=( $(compgen -W "${hashes}" -- "${cur}") )
                            ;;
                        apply)
                            COMPREPLY=( $(compgen -W "-d --delete" -- "${cur}") )
                            ;;
                    esac
                elif [[ "${COMP_WORDS[1]}" == "tag" && "${COMP_WORDS[2]}" == "edit" ]]; then
                    COMPREPLY=( $(compgen -W "--name --desc --message -m" -- "${cur}") )
                elif [[ "${COMP_WORDS[1]}" == "remote" && "${COMP_WORDS[2]}" == "update" ]]; then
                    COMPREPLY=( $(compgen -W "--name --url" -- "${cur}") )
                elif [[ "${COMP_WORDS[1]}" == "branch" && "${COMP_WORDS[2]}" == "rename" ]]; then
                    COMPREPLY=( $(compgen -W "--name" -- "${cur}") )
                fi
                ;;
            *)
                if [[ "${COMP_WORDS[1]}" == "history" && "${COMP_WORDS[2]}" == "join" ]]; then
                    local hashes
                    hashes=$(git log --pretty=format:'%h' -n 50 2>/dev/null)
                    COMPREPLY=( $(compgen -W "--message ${hashes}" -- "${cur}") )
                fi
                ;;
        esac
    }

    __g__.__init__() {
        __compl g
    }
}
