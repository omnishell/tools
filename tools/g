#! /bin/bash

__g__() {
    __g__.__help__() {
        cat <<'EOF' >&2
Usage: g <command> [options]

Top-level commands:
  all           Stage all modified files
  .             Stage files in current directory
  ..            Unstage files
  ,             Checkout or create branch
  info          Show last commit and status
  change        Manage present changes (info, ls, add, rm, undo, clean)
  history       Manage past history (session, join, rename, rm)
  commit        Manage snapshots (new, ls, send, diff)
  branch        Manage branches (new, ls, rm, send, rename, rebase, ff, merge, sync)
  tag           Manage tags (new, ls, rm, send, edit)
  conflict      Manage conflicts (ls, resolve, diff)
  remote        Manage remotes (new, ls, rm, update)
EOF
    }

    g() {
        if ! command -v "fzf" > /dev/null 2>&1; then
            echo "error: missing fzf." >&2
            return 1
        fi

        local cmd="${1:-}"
        case "$cmd" in
            -h|--help|"") __g__.__help__ ;;
            all) git add -A ;;
            .) 
                shift
                [[ "$1" == "-a" || "$1" == "--all" ]] && { git add -A; return 0; }
                git add "${@:-.}" 
                ;;
            ..) 
                shift
                [[ "$1" == "-a" || "$1" == "--all" ]] && { git reset HEAD -- .; return 0; }
                set -- "rm" "$@"
                local change_cmd="$1"
                shift || true
                case "$change_cmd" in
                    rm)
                        if [[ "$#" -eq 0 ]]; then
                            local repo_root current_dir staged
                            repo_root=$(git rev-parse --show-toplevel)
                            current_dir=$(pwd)
                            staged=$(git diff --cached --name-only | fzf --multi --prompt="Unstage file: " --height=30%)
                            if [[ -n "$staged" ]]; then
                                readarray -t files_to_unstage <<< "$staged"
                                local files_for_reset=() file
                                for file in "${files_to_unstage[@]}"; do
                                    local abs_from_root="$repo_root/$file"
                                    local rel_from_cwd
                                    if command -v realpath >/dev/null 2>&1; then
                                        rel_from_cwd=$(realpath --relative-to="$current_dir" "$abs_from_root" 2>/dev/null || echo "$file")
                                    else
                                        rel_from_cwd="$file"
                                    fi
                                    [[ -e "$rel_from_cwd" ]] && files_for_reset+=("$rel_from_cwd") || files_for_reset+=("$file")
                                done
                                [[ "${#files_for_reset[@]}" -eq 0 ]] && return 1
                                if git reset HEAD -- "${files_for_reset[@]}" > /dev/null; then
                                    for f in "${files_to_unstage[@]}"; do echo "- $f"; done
                                fi
                            fi
                        else
                            if git reset HEAD -- "$@" > /dev/null; then
                                for f in "$@"; do echo "- $f"; done
                            fi
                        fi
                        ;;
                esac
                ;;
            ,) 
                shift
                [[ -z "$1" ]] && { git branch; return 0; }
                git show-ref --verify --quiet "refs/heads/$1" && git checkout "$1" || git checkout -b "$1" 
                ;;
            info) 
                git log -1 --oneline
                git status 
                ;;
            git) 
                shift; git "$@" 
                ;;
            change) 
                shift
                local sub="$1"
                shift || true
                case "$sub" in
                    -h|--help|"") echo "Usage: g change {info|ls|add|rm|undo|clean}" >&2; return 0 ;;
                    info) git log -1 --oneline; git status ;;
                    ls|list) git diff --cached --name-only ;;
                    add)
                        local files="" selected
                        while read -r st f; do [[ "$st" =~ ^[MARCU?] ]] && files+="$f"$'\n'; done < <(git status --porcelain 2>/dev/null)
                        selected=$(printf '%s' "$files" | fzf --multi --prompt="Add file to stage: " --height=30%)
                        [[ -n "$selected" ]] && git add $selected
                        ;;
                    rm)
                        if [[ "$#" -eq 0 ]]; then
                            local repo_root current_dir staged
                            repo_root=$(git rev-parse --show-toplevel)
                            current_dir=$(pwd)
                            staged=$(git diff --cached --name-only | fzf --multi --prompt="Unstage file: " --height=30%)
                            if [[ -n "$staged" ]]; then
                                readarray -t files_to_unstage <<< "$staged"
                                local files_for_reset=() file
                                for file in "${files_to_unstage[@]}"; do
                                    local abs_from_root="$repo_root/$file"
                                    local rel_from_cwd
                                    if command -v realpath >/dev/null 2>&1; then
                                        rel_from_cwd=$(realpath --relative-to="$current_dir" "$abs_from_root" 2>/dev/null || echo "$file")
                                    else
                                        rel_from_cwd="$file"
                                    fi
                                    [[ -e "$rel_from_cwd" ]] && files_for_reset+=("$rel_from_cwd") || files_for_reset+=("$file")
                                done
                                [[ "${#files_for_reset[@]}" -eq 0 ]] && return 1
                                if git reset HEAD -- "${files_for_reset[@]}" > /dev/null; then
                                    for f in "${files_to_unstage[@]}"; do echo "- $f"; done
                                fi
                            fi
                        else
                            if git reset HEAD -- "$@" > /dev/null; then
                                for f in "$@"; do echo "- $f"; done
                            fi
                        fi
                        ;;
                    undo)
                        if [[ $# -eq 0 ]]; then
                            echo "Usage: g change undo <number>  OR  g change undo <path> [<path>...]" >&2
                            return 1
                        fi
                        if [[ $# -eq 1 && "$1" =~ ^[0-9]+$ ]]; then
                            local steps="$1" target_ref="HEAD~$steps"
                            git rev-parse --verify "$target_ref" >/dev/null 2>&1 || return 1
                            read -r -p "Discard all uncommitted changes and move HEAD back $steps commit(s)? [y/N] " answer
                            case "$answer" in [Yy]*) git reset --hard "$target_ref" ;; *) return 1 ;; esac
                        else
                            git restore -- "$@"
                        fi
                        ;;
                    clean) git clean -fd ;;
                    *) return 1 ;;
                esac
                ;;
            history) 
                shift
                local sub="$1"
                shift || true
                case "$sub" in
                    -h|--help|"") echo "Usage: g history {session|join|rename|rm}" >&2; return 0 ;;
                    session)
                        local subcmd="$1"
                        shift || true
                        local git_dir state_file
                        git_dir=$(git rev-parse --git-dir 2>/dev/null) || return 1
                        state_file="$git_dir/g-edit-state"
                        case "$subcmd" in
                            new)
                                local target="$1" commit_to_edit
                                shift || true
                                if [[ -z "$target" ]]; then
                                    local selected
                                    selected=$(git log --pretty=format:'%h %s [%an]' | fzf --prompt="Select commit to edit: " --height=50%)
                                    [[ -z "$selected" ]] && return 1
                                    commit_to_edit="${selected%% *}"
                                else
                                    if [[ "$target" =~ ^[0-9]+$ ]]; then commit_to_edit="HEAD~$target"
                                    else commit_to_edit="$target"; fi
                                fi
                                local commit_hash parent_hash current_branch
                                commit_hash=$(git rev-parse --verify "$commit_to_edit" 2>/dev/null) || return 1
                                parent_hash=$(git rev-parse "${commit_hash}^" 2>/dev/null) || return 1
                                current_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null)
                                [[ -z "$current_branch" ]] && return 1
                                [[ -f "$state_file" ]] && return 1
                                { printf '%s\n' "$current_branch"; printf '%s\n' "$commit_hash"; } > "$state_file"
                                local short_hash=${commit_hash:0:7} work_branch="g-edit-${short_hash}"
                                git branch "$work_branch" "$current_branch" || return 1
                                git checkout "$work_branch" || return 1
                                git reset --hard "$commit_hash" || return 1
                                git reset --soft "$parent_hash" || return 1
                                ;;
                            ls|list)
                                if [[ -f "$state_file" ]]; then
                                    local orig old
                                    { read -r orig; read -r old; } < "$state_file"
                                    echo "Active Edit Session:"
                                    echo "  Original branch: $orig"
                                    echo "  Target commit:   $old"
                                    echo "  Temp branch:     g-edit-${old:0:7}"
                                else
                                    echo "No active edit sessions."
                                fi
                                ;;
                            rm)
                                [[ ! -f "$state_file" ]] && return 1
                                local orig old
                                { read -r orig; read -r old; } < "$state_file"
                                git checkout "$orig"
                                git branch -D "g-edit-${old:0:7}" 2>/dev/null || true
                                rm -f "$state_file"
                                echo "Edit session removed."
                                ;;
                            apply)
                                local delete_temp_branch=0
                                while [[ $# -gt 0 ]]; do
                                    case "$1" in -d|--delete) delete_temp_branch=1 ;; *) return 1 ;; esac
                                    shift
                                done
                                [[ ! -f "$state_file" ]] && return 1
                                local original_branch old_commit_hash
                                { read -r original_branch; read -r old_commit_hash; } < "$state_file"
                                [[ -z "$original_branch" || -z "$old_commit_hash" ]] && return 1
                                git rev-parse --verify "$original_branch" >/dev/null 2>&1 || return 1
                                git rev-parse --verify "$old_commit_hash" >/dev/null 2>&1 || return 1
                                git rebase --onto HEAD "$old_commit_hash" "$original_branch" || return 1
                                rm -f "$state_file"
                                if [[ "$delete_temp_branch" -eq 1 ]]; then
                                    local temp_branch="g-edit-${old_commit_hash:0:7}"
                                    git show-ref --verify --quiet "refs/heads/$temp_branch" && git branch -D "$temp_branch"
                                fi
                                ;;
                            *) return 1 ;;
                        esac
                        ;;
                    join)
                        local git_dir head_full root_hash root_short commits=() message=""
                        git_dir=$(git rev-parse --git-dir 2>/dev/null) || return 1
                        git diff-index --quiet HEAD -- || return 1
                        head_full=$(git rev-parse HEAD)
                        root_hash=$(git rev-list --max-parents=0 HEAD 2>/dev/null | head -n1 || true)
                        [[ -n "$root_hash" ]] && root_short=$(git rev-parse --short "$root_hash" 2>/dev/null || true)
                        if [[ $# -eq 0 ]]; then
                            local commits_list=""
                            while read -r h rest; do
                                [[ -n "$root_short" && "$h" == "$root_short" ]] && continue
                                commits_list+="$h $rest"$'\n'
                            done < <(git log --pretty=format:'%h %s [%an]' 2>/dev/null)
                            local selected
                            selected=$(printf '%s' "$commits_list" | fzf --multi --prompt="Select commits to squash: " --height=50%)
                            [[ -z "$selected" ]] && return 1
                            local short_hashes=()
                            while IFS= read -r line; do [[ -n "$line" ]] && short_hashes+=("${line%% *}"); done <<< "$selected"
                            local h full
                            for h in "${short_hashes[@]}"; do
                                full=$(git rev-parse "$h" 2>/dev/null) || return 1
                                [[ -n "$root_hash" && "$full" == "$root_hash" ]] && continue
                                commits+=( "$full" )
                            done
                            read -r -p "Squash commit message: " message
                            [[ -z "$message" ]] && return 1
                        else
                            while [[ $# -gt 0 ]]; do
                                case "$1" in
                                    -m|--message) shift; message="$*"; break ;;
                                    *)
                                        local full
                                        full=$(git rev-parse "$1" 2>/dev/null) || return 1
                                        [[ -n "$root_hash" && "$full" == "$root_hash" ]] && return 1
                                        commits+=( "$full" )
                                        shift ;;
                                esac
                            done
                            [[ "${#commits[@]}" -lt 1 ]] && return 1
                            if [[ -z "$message" ]]; then
                                read -r -p "Squash commit message: " message
                                [[ -z "$message" ]] && return 1
                            fi
                        fi
                        [[ "${#commits[@]}" -lt 2 ]] && return 1
                        local c
                        for c in "${commits[@]}"; do
                            git merge-base --is-ancestor "$c" "$head_full" 2>/dev/null || return 1
                        done
                        local oldest="" max_dist=-1 dist
                        for c in "${commits[@]}"; do
                            if git rev-parse "${c}^" >/dev/null 2>&1; then dist=$(git rev-list --count "${c}^..HEAD")
                            else dist=$(git rev-list --count "${c}..HEAD"); fi
                            if [[ "$dist" -gt "$max_dist" ]]; then max_dist=$dist; oldest="$c"; fi
                        done
                        local parent_oldest
                        parent_oldest=$(git rev-parse "${oldest}^" 2>/dev/null) || return 1
                        read -r -p "Proceed? This rewrites history. [y/N] " answer2
                        case "$answer2" in [Yy]*) ;; *) return 1 ;; esac
                        git reset --soft "$parent_oldest" || return 1
                        git commit -m "$message" || return 1
                        ;;
                    rename)
                        local target_ref="" commit_hash="" new_message=""
                        if [[ "$#" -eq 0 ]]; then
                            local selected
                            selected=$(git log --pretty=format:'%h %s [%an]' | fzf --prompt="Select commit to rename: " --height=50% --layout=reverse --border)
                            [[ -z "$selected" ]] && return 1
                            target_ref="${selected%% *}"
                        else
                            target_ref="$1"; shift
                            [[ "$target_ref" =~ ^[0-9]+$ ]] && target_ref="HEAD~$target_ref"
                            while [[ "$#" -gt 0 ]]; do
                                case "$1" in -m|--message) shift; new_message="$*"; break ;; *) return 1 ;; esac
                            done
                        fi
                        commit_hash=$(git rev-parse --verify "$target_ref" 2>/dev/null) || return 1
                        if [[ -z "$new_message" ]]; then
                            local old_message
                            old_message=$(git log -1 --pretty=%B "$commit_hash")
                            read -r -p "New commit message: " new_message
                            [[ -z "$new_message" ]] && return 1
                        fi
                        local head_hash
                        head_hash=$(git rev-parse HEAD)
                        if [[ "$commit_hash" == "$head_hash" ]]; then
                            git commit --amend -m "$new_message"
                            return $?
                        fi
                        local parent_hash2 git_dir2 seq_editor msg_editor
                        parent_hash2=$(git rev-parse "${commit_hash}^" 2>/dev/null) || return 1
                        git_dir2=$(git rev-parse --git-dir 2>/dev/null) || return 1
                        seq_editor="$git_dir2/g-rename-sequence-editor.sh"
                        msg_editor="$git_dir2/g-rename-msg-editor.sh"
                        if [[ ! -x "$seq_editor" ]]; then
                            cat > "$seq_editor" <<'EOF'
#!/bin/sh
file="$1"
tmp="$file.tmp"
: > "$tmp"
target="$G_RENAME_TARGET"
while IFS= read -r line; do
    case "$line" in "pick $target "*) echo "reword ${line#pick }" >> "$tmp" ;; *) echo "$line" >> "$tmp" ;; esac
done < "$file"
mv "$tmp" "$file"
EOF
                            chmod +x "$seq_editor"
                        fi
                        if [[ ! -x "$msg_editor" ]]; then
                            cat > "$msg_editor" <<'EOF'
#!/bin/sh
file="$1"
printf '%s\n' "$G_RENAME_NEW_MESSAGE" > "$file"
EOF
                            chmod +x "$msg_editor"
                        fi
                        export G_RENAME_TARGET="$commit_hash"
                        export G_RENAME_NEW_MESSAGE="$new_message"
                        GIT_SEQUENCE_EDITOR="$seq_editor" GIT_EDITOR="$msg_editor" git rebase -i "$parent_hash2"
                        ;;
                    rm)
                        local targets=()
                        if [[ "$#" -eq 0 ]]; then
                            local selected
                            selected=$(git log --oneline | fzf --multi --prompt="Select commits to delete: " --height=50%)
                            [[ -z "$selected" ]] && return 1
                            while IFS= read -r line; do
                                [[ -z "$line" ]] && continue
                                local short="${line%% *}" local hash
                                if hash=$(git rev-parse --verify "$short" 2>/dev/null); then targets+=("$hash"); fi
                            done <<< "$selected"
                        else
                            local arg
                            for arg in "$@"; do
                                local ref hash
                                if [[ "$arg" =~ ^[0-9]+$ ]]; then
                                    local n="$arg"
                                    [[ "$n" -lt 1 ]] && return 1
                                    [[ "$n" -eq 1 ]] && ref="HEAD" || ref="HEAD~$n"
                                else
                                    ref="$arg"
                               fi
                               if ! hash=$(git rev-parse --verify "$ref" 2>/dev/null); then return 1; fi
                               targets+=("$hash")
                            done
                        fi
                        [[ "${#targets[@]}" -eq 0 ]] && return 1
                        local uniq_targets=() h s seen
                        for h in "${targets[@]}"; do
                            seen=0
                            for s in "${uniq_targets[@]}"; do [[ "$s" == "$h" ]] && seen=1 && break; done
                            [[ "$seen" -eq 0 ]] && uniq_targets+=("$h")
                        done
                        local head_hash base_commit=""
                        head_hash=$(git rev-parse HEAD)
                        for h in "${uniq_targets[@]}"; do
                            git merge-base --is-ancestor "$h" "$head_hash" 2>/dev/null || return 1
                        done
                        while IFS= read -r c; do
                            for h in "${uniq_targets[@]}"; do [[ "$h" == "$c" ]] && base_commit="$h" && break 2; done
                        done < <(git rev-list --reverse "$head_hash" 2>/dev/null)
                        [[ -z "$base_commit" ]] && return 1
                        local parent_hash
                        parent_hash=$(git rev-parse "${base_commit}^" 2>/dev/null) || return 1
                        read -r -p "Proceed with removing these commits? [y/n] " answer
                        case "$answer" in [Yy]*) ;; *) return 1 ;; esac
                        local git_dir seq_editor
                        git_dir=$(git rev-parse --git-dir 2>/dev/null) || return 1
                        seq_editor="$git_dir/g-rm-sequence-editor.sh"
                        cat > "$seq_editor" <<'EOF'
#!/bin/sh
file="$1"
tmp="$file.tmp"
targets=" $G_RM_COMMITS_FULL "
: > "$tmp"
while IFS= read -r line; do
    case "$line" in
        pick\ *|edit\ *|reword\ *|fixup\ *|squash\ *)
            set -- $line
            cmd="$1"
            hash="$2"
            full_hash=$(command git rev-parse --verify "$hash" 2>/dev/null || echo "")
            if [ -n "$full_hash" ]; then
                case "$targets" in *" $full_hash "*) echo "drop ${line#* }" >> "$tmp"; continue ;; esac
            fi
            echo "$line" >> "$tmp"
            ;;
        *) echo "$line" >> "$tmp" ;;
    esac
done < "$file"
mv "$tmp" "$file"
EOF
                        chmod +x "$seq_editor"
                        export G_RM_COMMITS_FULL="${uniq_targets[*]}"
                        GIT_SEQUENCE_EDITOR="$seq_editor" git rebase -i "$parent_hash"
                        ;;
                    *) return 1 ;;
                esac
                ;;
            commit)
                shift
                local subcmd="$1"
                shift || true
                case "$subcmd" in
                    new)
                        local msg=""
                        if [[ $# -eq 0 ]]; then read -e -p "Commit message: " msg
                        else msg="$*"; fi
                        [[ -z "$msg" ]] && return 1
                        git commit -m "$msg"
                        ;;
                    list|ls) git log --oneline --decorate --graph -n "${1:-10}" ;;
                    send)
                        local force_flag=0 target_ref="HEAD"
                        while [[ $# -gt 0 ]]; do
                            case "$1" in -f|--force) force_flag=1 ;; *) target_ref="$1" ;; esac
                            shift
                        done
                        if [[ "$force_flag" -eq 1 ]]; then git push --force origin "$target_ref"
                        else git push origin "$target_ref"; fi
                        ;;
                    diff)
                        if [[ $# -eq 0 ]]; then git diff; return; fi
                        git difftool -t vimdiff -y "$@"
                        ;;
                    *)
                        if [[ -n "$subcmd" && "$subcmd" == *":" ]]; then
                            local msg="" ctx=""
                            while [[ $# -gt 0 ]]; do
                                case "$1" in -c|--context) ctx="$2"; shift 2 ;; *) msg+="${msg:+ }$1"; shift ;; esac
                            done
                            local type="${subcmd%:}" prefix="$type"
                            [[ -n "$ctx" ]] && prefix="$type($ctx)"
                            git commit -m "${prefix}: ${msg}"
                            return
                        fi
                        return 1
                        ;;
                esac
                ;;
            branch)
                shift
                local sub="${1:-}"
                shift || true
                case "$sub" in
                    -h|--help) echo "Usage: g branch {new|ls|rm|send|rename|rebase|ff|merge|sync}" >&2; return 0 ;;
                    "") git branch; return 0 ;;
                    new) [[ -n "$1" ]] && git checkout -b "$1" || return 1 ;;
                    list|ls) git branch -a ;;
                    rm)
                        local selected branch
                        if [[ -z "$1" ]]; then
                            selected=$(git branch --format="%(refname:short)" | fzf --multi --prompt="Branch to delete: " --height=30%)
                            [[ -n "$selected" ]] && while read -r branch; do git branch -D "$branch"; done <<< "$selected"
                        else
                            git branch -D "$1"
                        fi
                        ;;
                    send) git push origin "${1:-HEAD}" ;;
                    sync) git pull "${1:-origin}" --ff ;;
                    rename)
                        local target_branch="" new_name=""
                        if [[ "$#" -gt 0 && "$1" != --* ]]; then target_branch="$1"; shift; fi
                        while [[ "$#" -gt 0 ]]; do
                            case "$1" in --name) new_name="$2"; shift 2 ;; *) return 1 ;; esac
                        done
                        if [[ -z "$target_branch" ]]; then
                            target_branch=$(git branch --format="%(refname:short)" | fzf --prompt="Branch to rename: " --height=30% --layout=reverse --border)
                            [[ -z "$target_branch" ]] && return 1
                        else
                            git show-ref --verify --quiet "refs/heads/$target_branch" || return 1
                        fi
                        if [[ -z "$new_name" ]]; then
                            read -r -p "New name for branch '$target_branch': " new_name
                            [[ -z "$new_name" ]] && return 1
                        fi
                        git branch -m "$target_branch" "$new_name"
                        ;;
                    rebase|ff)
                        local remote="origin" branches=() op="$sub"
                        while [[ "$#" -gt 0 ]]; do
                            case "$1" in -r|--remote) remote="$2"; shift 2 ;; *) branches+=("$1"); shift ;; esac
                        done
                        local current_branch start_branch b target_branch
                        current_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)
                        start_branch="$current_branch"
                        if [[ "${#branches[@]}" -eq 0 ]]; then
                            [[ "$op" == "rebase" ]] && git pull "$remote" HEAD --rebase || git pull "$remote" HEAD --ff
                            return $?
                        fi
                        for b in "${branches[@]}"; do
                            target_branch="$b"
                            [[ "$b" == "./HEAD" ]] && target_branch="$current_branch"
                            [[ -z "$target_branch" ]] && continue
                            git show-ref --verify --quiet "refs/heads/$target_branch" || continue
                            git checkout "$target_branch" || continue
                            if [[ "$op" == "rebase" ]]; then
                                git pull "$remote" "$target_branch" --rebase || { [[ -n "$start_branch" ]] && git checkout "$start_branch" >/dev/null 2>&1; return 1; }
                            else
                                git pull "$remote" "$target_branch" --ff || { [[ -n "$start_branch" ]] && git checkout "$start_branch" >/dev/null 2>&1; return 1; }
                            fi
                        done
                        [[ -n "$start_branch" ]] && git show-ref --verify --quiet "refs/heads/$start_branch" && git checkout "$start_branch" >/dev/null 2>&1 || true
                        ;;
                    merge)
                        local branches=() message=""
                        while [[ "$#" -gt 0 ]]; do
                            case "$1" in -m|--message) shift; message="$*"; break ;; *) branches+=("$1"); shift ;; esac
                        done
                        if [[ "${#branches[@]}" -eq 0 ]]; then
                            local selected
                            selected=$(git branch --format="%(refname:short)" | fzf --multi --prompt="Branches to merge into current: " --height=40% --layout=reverse --border)
                            [[ -z "$selected" ]] && return 1
                            read -r -a branches <<< "$selected"
                        fi
                        local b
                        for b in "${branches[@]}"; do git show-ref --verify --quiet "refs/heads/$b" || return 1; done
                        if [[ -z "$message" ]]; then
                            read -r -p "Merge commit message: " message
                            [[ -z "$message" ]] && return 1
                        fi
                        git merge "${branches[@]}" -m "$message"
                        ;;
                    *)
                        git show-ref --verify --quiet "refs/heads/$sub" && git checkout "$sub" || git branch "$sub" "$@"
                        ;;
                esac
                ;;
            tag|tags)
                shift
                local subcmd="${1:-}" local all_args=("$subcmd" "${@:2}")
                shift || true
                case "$subcmd" in
                    -h|--help) echo "Usage: g tag {new|ls|rm|send|edit}" >&2; return 0 ;;
                    new)
                        local tagtype="$1" msg=""
                        shift || true
                        while [[ $# -gt 0 ]]; do
                            case "$1" in -m|--message) msg="$2"; shift 2 ;; *) shift ;; esac
                        done
                        [[ -z "$tagtype" ]] && return 1
                        local latest_tag new_tag
                        latest_tag=$(git describe --tags --abbrev=0 2>/dev/null)
                        if [[ -z "$latest_tag" ]]; then new_tag="v0.1.0"
                        else
                            local major minor patch
                            IFS='.' read -r major minor patch <<< "${latest_tag#v}"
                            case "$tagtype" in
                                patch) patch=$((patch + 1));;
                                minor) minor=$((minor + 1)); patch=0;;
                                major) major=$((major + 1)); minor=0; patch=0;;
                                *) return 1 ;;
                            esac
                            new_tag="v$major.$minor.$patch"
                        fi
