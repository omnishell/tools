#! /bin/bash

__g__() {
    g.__help__() {
        cat <<'EOF' >&2
Usage: g <command> [options]

Top-level commands:
  info          Show last commit and status
  undo          Undo commits or restore paths
  new           Create a commit
  ls, list      List recent commits
  rm            Remove commits (interactive rebase)
  edit          Edit a past commit on a temp branch
  rename        Update a commit message
  join          Squash commits
  send          Push commits
  get           Pull commits
  diff          Show diffs

Command groups:
  branch        Branch-related commands
  tag           Tag-related commands
  stage         Staging area commands
  conflict      Conflict inspection
  remote        Remote management

Run:
  g <group> -h      for group-specific help, e.g. 'g tag -h'
EOF
    }

    __g__.general() {
        local cmd="$1"
        shift || true

        case "$cmd" in
            undo)
                if [ $# -eq 0 ]; then
                    echo "Usage: g undo <number>  OR  g undo <path> [<path>...]" >&2
                    return 1
                fi
                if [ $# -eq 1 ] && [[ "$1" =~ ^[0-9]+$ ]]; then
                    local steps="$1"
                    local target_ref="HEAD~$steps"
                    if ! git rev-parse --verify "$target_ref" >/dev/null 2>&1; then
                        echo "Target commit '$target_ref' does not exist." >&2
                        return 1
                    fi
                    echo "This will run: git reset --hard $target_ref"
                    read -r -p "Are you sure you want to discard all uncommitted changes and move HEAD back $steps commit(s)? [y/N] " answer
                    case "$answer" in
                        [Yy]*) git reset --hard "$target_ref" ;;
                        *) echo "Aborted."; return 1 ;;
                    esac
                else
                    git restore -- "$@"
                fi
                ;;
            info)
                git log -1 --oneline
                git status
                ;;
            apply)
                local delete_temp_branch=0
                while [ $# -gt 0 ]; do
                    case "$1" in
                        -d|--delete) delete_temp_branch=1 ;;
                        *) echo "Usage: g apply [-d|--delete]" >&2; return 1 ;;
                    esac
                    shift
                done
                local git_dir
                git_dir=$(git rev-parse --git-dir 2>/dev/null) || { echo "Not inside a git repository." >&2; return 1; }
                local state_file="$git_dir/g-edit-state"
                if [ ! -f "$state_file" ]; then
                    echo "No pending edit state found. Run 'g edit <hash|number>' first." >&2
                    return 1
                fi
                local original_branch old_commit_hash
                { read -r original_branch; read -r old_commit_hash; } < "$state_file"
                if [ -z "$original_branch" ] || [ -z "$old_commit_hash" ]; then
                    echo "Edit state file is invalid. Delete it and run 'g edit' again." >&2
                    return 1
                fi
                if ! git rev-parse --verify "$original_branch" >/dev/null 2>&1; then
                    echo "Original branch '$original_branch' not found. Aborting." >&2
                    return 1
                fi
                if ! git rev-parse --verify "$old_commit_hash" >/dev/null 2>&1; then
                    echo "Old commit '$old_commit_hash' not found. Aborting." >&2
                    return 1
                fi
                echo "Applying edited history onto original branch '$original_branch'..."
                git rebase --onto HEAD "$old_commit_hash" "$original_branch" || return 1
                rm -f "$state_file"
                if [ "$delete_temp_branch" -eq 1 ]; then
                    local short_hash=${old_commit_hash:0:7}
                    local temp_branch="g-edit-${short_hash}"
                    if git show-ref --verify --quiet "refs/heads/$temp_branch"; then
                        echo "Deleting temporary branch '$temp_branch'..."
                        git branch -D "$temp_branch"
                    else
                        echo "No temporary branch '$temp_branch' found to delete."
                    fi
                fi
                echo -e "\nRebase completed successfully."
                ;;
            .)
                if [[ "$1" == "-a" || "$1" == "--all" ]]; then
                    shift
                    local repo_root
                    repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || return 1
                    git -C "$repo_root" add -A
                    echo "Added all modified files to stage."
                    return $?
                fi
                if [ -z "$1" ]; then
                    __g__.general info
                elif [[ "$1" == "." ]]; then
                    if git add .; then
                        echo "All modified files in \"$PWD\" added to stage."
                    else
                        echo "Error adding all changes to stage." >&2
                    fi
                else
                    if git add -- "$@"; then
                        local staged_now
                        staged_now=$(git diff --cached --name-only -- "$@" 2>/dev/null)
                        if [ -z "$staged_now" ]; then
                            echo "No changes added to stage."
                            return 0
                        fi
                        echo "Files added to stage:"
                        while read -r i; do
                            [[ -n "$i" ]] && { [ -d "$i" ] && echo "- $i/*" || echo "- $i"; }
                        done <<< "$staged_now"
                    else
                        echo "Error adding specified files." >&2
                    fi
                fi
                ;;
            ,)
                if [[ -z "$1" ]]; then g.branch; return; fi
                local branch
                while read -r branch; do
                    if [[ "$1" == "$branch" ]]; then g.branch "$branch"; return; fi
                done < <(git branch --format="%(refname:short)")
                __g__.branch new "$1"
                ;;
            ..)
                if [[ "$1" == "-a" || "$1" == "--all" ]]; then
                    shift
                    local repo_root
                    repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || return 1
                    ( cd "$repo_root" || exit 1; g.general .. . > /dev/null 2>&1 )
                    echo "All staged files have been unstaged."
                    return $?
                fi
                if [ "$#" -eq 0 ]; then g.stage rm; else g.stage rm "$@"; fi
                ;;
            ,.|.,) __g__.stage ls ;;
            git) git "$@" ;;
            *) echo "Unknown general command: $cmd" >&2; return 1 ;;
        esac
    }

    __g__.branch() {
        local sub="${1:-}"
        shift || true
        case "$sub" in
            -h|--help)
                echo "Usage: g branch {new|ls|rm|send|rename|rebase|ff|merge}" >&2
                return 0
                ;;
            "") git branch; return 0 ;;
            new)
                if [ -n "$1" ]; then git checkout -b "$1"
                else echo "Usage: g branch new <branch-name>" >&2; return 1; fi
                ;;
            list|ls) git branch -a ;;
            rm)
                local selected branch
                if [ -z "$1" ]; then
                    selected=$(git branch --format="%(refname:short)" | fzf --multi --prompt="Branch to delete: " --height=30%)
                    [ -n "$selected" ] && for branch in $selected; do git branch -D "$branch"; done
                else
                    git branch -D "$1"
                fi
                ;;
            send)
                local branch_to_push="${1:-HEAD}"
                git push origin "${branch_to_push}"
                ;;
            rename)
                local target_branch="" new_name=""
                if [ "$#" -gt 0 ] && [[ "$1" != --* ]]; then
                    target_branch="$1"; shift
                fi
                while [ "$#" -gt 0 ]; do
                    case "$1" in
                        --name) shift; new_name="$1" ;;
                        *) return 1 ;;
                    esac
                    shift
                done
                if [ -z "$target_branch" ]; then
                    local selected
                    selected=$(git branch --format="%(refname:short)" | fzf --prompt="Branch to rename: " --height=30% --layout=reverse --border)
                    [ -z "$selected" ] && return 1
                    target_branch="$selected"
                else
                    if ! git show-ref --verify --quiet "refs/heads/$target_branch"; then
                        echo "Branch '$target_branch' does not exist." >&2
                        return 1
                    fi
                fi
                if [ -z "$new_name" ]; then
                    read -r -p "New name for branch '$target_branch': " new_name
                    [ -z "$new_name" ] && return 1
                fi
                git branch -m "$target_branch" "$new_name"
                ;;
            rebase|ff)
                local remote="origin" branches=() op="$sub"
                while [ "$#" -gt 0 ]; do
                    case "$1" in
                        -r|--remote) shift; remote="${1:-origin}" ;;
                        *) branches+=("$1") ;;
                    esac
                    shift
                done
                local current_branch
                current_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)
                if [ "${#branches[@]}" -eq 0 ]; then
                    [[ "$op" == "rebase" ]] && git pull "$remote" HEAD --rebase || git pull "$remote" HEAD --ff
                    return $?
                fi
                local start_branch="$current_branch" b target_branch
                for b in "${branches[@]}"; do
                    target_branch="$b"
                    if [ "$b" = "./HEAD" ]; then
                        [ -z "$current_branch" ] && return 1
                        target_branch="$current_branch"
                    fi
                    if ! git show-ref --verify --quiet "refs/heads/$target_branch"; then continue; fi
                    git checkout "$target_branch" || continue
                    if [[ "$op" == "rebase" ]]; then
                        git pull "$remote" "$target_branch" --rebase || { [[ -n "$start_branch" ]] && git checkout "$start_branch" >/dev/null 2>&1; return 1; }
                    else
                        git pull "$remote" "$target_branch" --ff || { [[ -n "$start_branch" ]] && git checkout "$start_branch" >/dev/null 2>&1; return 1; }
                    fi
                done
                if [ -n "$start_branch" ] && git show-ref --verify --quiet "refs/heads/$start_branch"; then
                    git checkout "$start_branch" >/dev/null 2>&1 || true
                fi
                ;;
            merge)
                local branches=() message=""
                while [ "$#" -gt 0 ]; do
                    case "$1" in
                        -m|--message) shift; message="$*"; break ;;
                        *) branches+=("$1") ;;
                    esac
                    shift
                done
                if [ "${#branches[@]}" -eq 0 ]; then
                    local selected
                    selected=$(git branch --format="%(refname:short)" | fzf --multi --prompt="Branches to merge into current: " --height=40% --layout=reverse --border)
                    [ -z "$selected" ] && return 1
                    read -r -a branches <<< "$selected"
                fi
                local b
                for b in "${branches[@]}"; do
                    if ! git show-ref --verify --quiet "refs/heads/$b"; then return 1; fi
                done
                if [ -z "$message" ]; then
                    read -r -p "Merge commit message: " message
                    [ -z "$message" ] && return 1
                fi
                git merge "${branches[@]}" -m "$message"
                ;;
            *)
                if git show-ref --verify --quiet "refs/heads/$sub"; then
                   git checkout "$sub"
                else
                    git branch "$sub" "$@"
                fi
                ;;
        esac
    }

    __g__.remote() {
        local sub="${1:-}"
        shift || true
        case "$sub" in
            -h|--help)
                echo "Usage: g remote {new|ls|rm|update}" >&2
                return 0
                ;;
            new)
                local name="" url=""
                while [ "$#" -gt 0 ]; do
                    case "$1" in
                        --name) shift; name="$1" ;;
                        --url) shift; url="$1" ;;
                        *)
                            if [ -z "$name" ]; then name="$1"
                            elif [ -z "$url" ]; then url="$1"
                            else return 1; fi
                            ;;
                    esac
                    shift
                done
                [ -z "$name" ] || [ -z "$url" ] && return 1
                git remote add "$name" "$url"
                ;;
            list|ls)
                local -A seen
                while read -r name url _; do
                    if [[ -n "$name" && -z "${seen["$name $url"]:-}" ]]; then
                        printf "%-20s %s\n" "$name" "$url"
                        seen["$name $url"]=1
                    fi
                done < <(git remote -v 2>/dev/null)
                ;;
            rm)
                local targets=()
                if [ "$#" -eq 0 ]; then
                    local remotes=""
                    while read -r name _; do
                        remotes+="$name"$'\n'
                    done < <(git remote -v 2>/dev/null)
                    remotes=$(printf '%s' "$remotes" | sort -u)
                    [ -z "$remotes" ] && return 1
                    local selected
                    selected=$(printf '%s\n' "$remotes" | fzf --multi --prompt="Remotes to delete: " --height=40% --layout=reverse --border)
                    [ -z "$selected" ] && return 1
                    while IFS= read -r line; do
                        [ -n "$line" ] && targets+=("${line%%$'\t'*}")
                    done <<< "$selected"
                else
                    local arg
                    for arg in "$@"; do
                        if git remote get-url "$arg" >/dev/null 2>&1; then
                            targets+=("$arg")
                        else
                            while read -r name url _; do
                                [[ "$url" == "$arg" ]] && targets+=("$name")
                            done < <(git remote -v 2>/dev/null)
                        fi
                    done
                fi
                [ "${#targets[@]}" -eq 0 ] && return 1
                local uniq_targets=() t u skip
                for t in "${targets[@]}"; do
                    skip=0
                    for u in "${uniq_targets[@]}"; do [[ "$u" = "$t" ]] && skip=1 && break; done
                    [ "$skip" -eq 0 ] && uniq_targets+=("$t")
                done
                echo "Remotes to delete: ${uniq_targets[*]}"
                read -r -p "Are you sure? [y/N] " ans
                case "$ans" in [Yy]*) ;; *) return 1 ;; esac
                local r
                for r in "${uniq_targets[@]}"; do git remote remove "$r"; done
                ;;
            update)
                local remote_name="$1"
                shift || true
                [ -z "$remote_name" ] && return 1
                local new_name="" new_url=""
                while [ "$#" -gt 0 ]; do
                    case "$1" in
                        --name) shift; new_name="$1" ;;
                        --url) shift; new_url="$1" ;;
                        *) return 1 ;;
                    esac
                    shift
                done
                if [ -z "$new_name" ] && [ -z "$new_url" ]; then return 1; fi
                if ! git remote get-url "$remote_name" >/dev/null 2>&1; then return 1; fi
                if [ -n "$new_name" ] && [ "$new_name" != "$remote_name" ]; then
                    git remote rename "$remote_name" "$new_name" || return 1
                    remote_name="$new_name"
                fi
                if [ -n "$new_url" ]; then
                    git remote set-url "$remote_name" "$new_url" || return 1
                fi
                ;;
            *) return 1 ;;
        esac
    }

    __g__.stage() {
        local sub="${1:-}"
        shift || true
        case "$sub" in
            -h|--help|"") echo "Usage: g stage {add|ls|rm}" >&2; return 0 ;;
            add)
                local files="" selected
                while read -r st f; do [[ "$st" =~ ^[MARCU?] ]] && files+="$f"$'\n'; done < <(git status --porcelain 2>/dev/null)
                selected=$(printf '%s' "$files" | fzf --multi --prompt="Add file to stage: " --height=30%)
                [ -n "$selected" ] && git add $selected
                ;;
            list|ls) git diff --cached --name-only ;;
            rm)
                if [ "$#" -eq 0 ]; then
                    local repo_root current_dir staged
                    repo_root=$(git rev-parse --show-toplevel)
                    current_dir=$(pwd)
                    staged=$(git diff --cached --name-only | fzf --multi --prompt="Unstage file: " --height=30%)
                    if [ -n "$staged" ]; then
                        readarray -t files_to_unstage <<< "$staged"
                        local files_for_reset=() file
                        for file in "${files_to_unstage[@]}"; do
                            local abs_from_root="$repo_root/$file"
                            local rel_from_cwd
                            if command -v realpath >/dev/null 2>&1; then
                                rel_from_cwd=$(realpath --relative-to="$current_dir" "$abs_from_root" 2>/dev/null || echo "$file")
                            else
                                rel_from_cwd="$file"
                            fi
                            [ -e "$rel_from_cwd" ] && files_for_reset+=("$rel_from_cwd") || files_for_reset+=("$file")
                        done
                        [ "${#files_for_reset[@]}" -eq 0 ] && return 1
                        if git reset HEAD -- "${files_for_reset[@]}" > /dev/null; then
                            for f in "${files_to_unstage[@]}"; do echo "- $f"; done
                        fi
                    fi
                else
                    if git reset HEAD -- "$@" > /dev/null; then
                        for f in "$@"; do echo "- $f"; done
                    fi
                fi
                ;;
            *) return 1 ;;
        esac
    }

    __g__.conflict() {
        local sub="${1:-}"
        shift || true
        case "$sub" in
            -h|--help)
                echo "Usage: g conflict {ls|resolve|diff|<branch>}" >&2
                return 0
                ;;
            ""|"HEAD")
                local current_branch
                current_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || echo "HEAD")
                local files
                files=$(git diff --name-only --diff-filter=U)
                if [ -z "$files" ]; then
                    echo "No merge conflicts."
                else
                    echo "Conflicts in:"; printf '  %s\n' $files
                fi
                ;;
            ls|list)
                local files="" file
                if [ $# -eq 0 ]; then
                    files=$(git diff --name-only --diff-filter=U)
                    [ -z "$files" ] && return 0
                else
                    files="$*"
                fi
                for file in $files; do
                    [ ! -f "$file" ] && continue
                    if ! grep -q '^<<<<<<< ' "$file" 2>/dev/null; then continue; fi
                    echo "===== Conflicts in $file ====="
                    local c=0 showing=0 ln=0
                    while IFS= read -r line; do
                        ((ln++))
                        if [[ "$line" == "<<<<<<< "* ]]; then
                            ((c++)); showing=1
                            printf "----- Conflict %d (start line %d) -----\n" "$c" "$ln"
                        fi
                        ((showing)) && printf '%s\n' "$line"
                        if [[ "$line" == ">>>>>>> "* ]]; then
                            printf "----- End of conflict %d (line %d) -----\n\n" "$c" "$ln"
                            showing=0
                        fi
                    done < "$file"
                done
                ;;
            resolve)
                local git_dir
                git_dir=$(git rev-parse --git-dir 2>/dev/null) || return 1
                local state_file="$git_dir/g-edit-state"
                if [ -z "$1" ] && [ ! -f "$state_file" ]; then
                    local files
                    files=$(git diff --name-only --diff-filter=U)
                    [ -z "$files" ] && return 0
                fi
                if [ ! -f "$state_file" ]; then
                    local current_branch
                    current_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)
                    [ -z "$current_branch" ] && return 1
                    local old_commit_hash
                    old_commit_hash=$(git rev-parse HEAD)
                    local has_rebase=0 has_merge=0
                    [ -d "$git_dir/rebase-apply" ] || [ -d "$git_dir/rebase-merge" ] && has_rebase=1
                    [ -f "$git_dir/MERGE_HEAD" ] && has_merge=1
                    if [ "$has_rebase" -eq 1 ]; then return 1; fi
                    if [ "$has_merge" -eq 1 ]; then
                        local merge_head merge_msg
                        merge_head=$(cat "$git_dir/MERGE_HEAD" 2>/dev/null || true)
                        merge_msg=$(cat "$git_dir/MERGE_MSG" 2>/dev/null || true)
                        [ -z "$merge_head" ] && return 1
                        read -r -p "Proceed? [y/N] " ans
                        case "$ans" in [Yy]*) ;; *) return 1 ;; esac
                        { printf '%s\n' "$current_branch"; printf '%s\n' "$old_commit_hash"; } > "$state_file"
                        local short_hash=${old_commit_hash:0:7}
                        local work_branch="g-edit-${short_hash}"
                        git merge --abort || { rm -f "$state_file"; return 1; }
                        git branch "$work_branch" "$old_commit_hash" || { rm -f "$state_file"; return 1; }
                        git checkout "$work_branch" || { rm -f "$state_file"; return 1; }
                        if [ -n "$merge_msg" ]; then git merge -m "$merge_msg" "$merge_head" || true
                        else git merge "$merge_head" || true; fi
                    else
                        { printf '%s\n' "$current_branch"; printf '%s\n' "$old_commit_hash"; } > "$state_file"
                        local short_hash=${old_commit_hash:0:7}
                        local work_branch="g-edit-${short_hash}"
                        git branch "$work_branch" "$current_branch" || { rm -f "$state_file"; return 1; }
                        git checkout "$work_branch" || { rm -f "$state_file"; return 1; }
                    fi
                else
                    local original_branch old_commit_hash
                    { read -r original_branch; read -r old_commit_hash; } < "$state_file"
                    local expected_branch="g-edit-${old_commit_hash:0:7}"
                    local current_branch
                    current_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)
                    if [ "$current_branch" != "$expected_branch" ]; then return 1; fi
                fi
                if [ -z "$1" ]; then
                    local files
                    files=$(git diff --name-only --diff-filter=U)
                    [ -z "$files" ] && return 0
                    local selected
                    selected=$(printf '%s\n' $files | fzf --multi --prompt="Select files to resolve: " --height=40% --layout=reverse --border)
                    [ -z "$selected" ] && return 1
                    local f
                    for f in $selected; do g.conflict resolve "$f" || return 1; done
                else
                    local file="$1"
                    [ ! -f "$file" ] && return 1
                    if ! grep -q '^<<<<<<< ' "$file" 2>/dev/null; then return 0; fi
                    local tmp_out tmp_ours tmp_theirs
                    tmp_out=$(mktemp); tmp_ours=$(mktemp); tmp_theirs=$(mktemp)
                    local in_conflict=0 side=""
                    local -a block_lines ours_lines theirs_lines
                    while IFS= read -r line || [ -n "$line" ]; do
                        if [ "$in_conflict" -eq 0 ]; then
                            case "$line" in
                                "<<<<<<< "*) in_conflict=1; side="ours"; block_lines=("$line"); ours_lines=(); theirs_lines=() ;;
                                *) printf '%s\n' "$line" >> "$tmp_out" ;;
                            esac
                        else
                            case "$side" in
                                ours)
                                    if [ "$line" = "=======" ]; then block_lines+=("$line"); side="theirs"
                                    else block_lines+=("$line"); ours_lines+=("$line"); fi ;;
                                theirs)
                                    block_lines+=("$line")
                                    case "$line" in
                                        ">>>>>>> "*)
                                            printf '%s\n' "${ours_lines[@]}" > "$tmp_ours"
                                            printf '%s\n' "${theirs_lines[@]}" > "$tmp_theirs"
                                            local plus_file minus_file
                                            plus_file=$(mktemp "/tmp/plus-XXXX")
                                            minus_file=$(mktemp "/tmp/minus-XXXX")
                                            cp "$tmp_ours" "$plus_file"
                                            cp "$tmp_theirs" "$minus_file"
                                            git --no-pager diff --no-index --color "$plus_file" "$minus_file" || true
                                            while true; do
                                                if ! read -r -p "Choose [+] plus, [-] minus, [+-] or [-+], [Enter=skip], [q/quit]: " ans </dev/tty; then
                                                    rm -f "$tmp_out" "$tmp_ours" "$tmp_theirs" "$plus_file" "$minus_file"; return 1
                                                fi
                                                case "$ans" in
                                                    "+") printf '%s\n' "${ours_lines[@]}" >> "$tmp_out"; break ;;
                                                    "-") printf '%s\n' "${theirs_lines[@]}" >> "$tmp_out"; break ;;
                                                    "+-") printf '%s\n' "${ours_lines[@]}" >> "$tmp_out"; printf '%s\n' "${theirs_lines[@]}" >> "$tmp_out"; break ;;
                                                    "-+") printf '%s\n' "${theirs_lines[@]}" >> "$tmp_out"; printf '%s\n' "${ours_lines[@]}" >> "$tmp_out"; break ;;
                                                    "") printf '%s\n' "${block_lines[@]}" >> "$tmp_out"; break ;;
                                                    q|Q|quit|QUIT) rm -f "$tmp_out" "$tmp_ours" "$tmp_theirs" "$plus_file" "$minus_file"; return 1 ;;
                                                esac
                                            done
                                            rm -f "$plus_file" "$minus_file"
                                            in_conflict=0; side=""; block_lines=(); ours_lines=(); theirs_lines=() ;;
                                        *) theirs_lines+=("$line") ;;
                                    esac ;;
                            esac
                        fi
                    done < "$file"
                    rm -f "$tmp_ours" "$tmp_theirs"
                    if [ "$in_conflict" -ne 0 ]; then rm -f "$tmp_out"; return 1; fi
                    mv "$tmp_out" "$file"
                fi
                ;;
            diff)
                local file="$1" tmp_ours tmp_theirs
                tmp_ours=$(mktemp); tmp_theirs=$(mktemp)
                if ! git show ":2:$file" >"$tmp_ours" 2>/dev/null || ! git show ":3:$file" >"$tmp_theirs" 2>/dev/null; then
                    rm -f "$tmp_ours" "$tmp_theirs"; return 1
                fi
                vimdiff "$tmp_ours" "$tmp_theirs"
                local status=$?
                rm -f "$tmp_ours" "$tmp_theirs"
                return $status
                ;;
            *)
                local target_branch="$sub"
                if ! git rev-parse --verify "$target_branch" >/dev/null 2>&1; then return 1; fi
                local current_branch base out
                current_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || echo "HEAD")
                if ! base=$(git merge-base HEAD "$target_branch" 2>/dev/null); then return 1; fi
                out=$(git merge-tree "$base" HEAD "$target_branch") || true
                if printf '%s\n' "$out" | grep -q '^<<<<<<< '; then echo "Merging WOULD produce conflicts."; else echo "Merging would NOT produce conflicts."; fi
                ;;
        esac
    }

    g.__tag__() {
        local sub="${1:-}"
        local all_args=("$@")
        shift || true
        case "$sub" in
            -h|--help) echo "Usage: g tag {new|ls|rm|send|update}" >&2; return 0 ;;
            new)
                local tagtype="$1"; shift 1 || true
                local msg="$*"
                [ -z "$tagtype" ] && return 1
                local latest_tag new_tag
                latest_tag=$(git describe --tags --abbrev=0 2>/dev/null)
                if [ -z "$latest_tag" ]; then
                    new_tag="v0.1.0"
                else
                    local major minor patch
                    IFS='.' read major minor patch <<< "${latest_tag#v}"
                    case "$tagtype" in
