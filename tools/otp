#! /bin/bash

__otp__() {
    otp.__help__() {
        >&2 cat <<'EOF'
ABOUT:
    omni multi factor authentication (OTP) tool

USAGE:
    otp [--file FILE] <command> [options]

COMMANDS:
    new     creates a new entry
    rm      removes existing entry
    list    list registered entries
    <name>  provide code for registered entry

GLOBALS:
    --file <file>  Path to the secrets file.
    --help, -h     Show this help message and exit.

ENVIRONMENT:
    OTP_SECRETS_FILE: set secrets file globally.
EOF
    }

    otp.new() {
        local name="" url="" service="" user="" secret_val=""
        local positional=() j=0

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --name) name="$2"; shift 2 ;;
                --url) url="$2"; shift 2 ;;
                --service) service="$2"; shift 2 ;;
                --user) user="$2"; shift 2 ;;
                --secret) secret_val="$2"; shift 2 ;;
                -*) __log "unknown option for 'new': $1" -t error -l otp; return 1 ;;
                *) positional+=("$1"); shift ;;
            esac
        done

        [[ -z "$name" && ${#positional[@]} -ge 1 ]] && name="${positional[0]}"
        [[ -z "$url" && ${#positional[@]} -ge 2 ]] && url="${positional[1]}"

        if [[ -n "$url" ]]; then
            if [[ -n "$service" || -n "$user" || -n "$secret_val" ]]; then
                __log "specify either --url or (--service/--user/--secret), not both." -t error -l otp
                return 1
            fi
        else
            if [[ -n "$service" || -n "$user" || -n "$secret_val" ]]; then
                if [[ -z "$service" || -z "$secret_val" ]]; then
                    __log "--service and --secret are required when not using --url." -t error -l otp
                    return 1
                fi
                local label="$service"
                [[ -n "$user" ]] && label="$service:$user"
                url="otpauth://totp/$label?secret=$secret_val&issuer=$service&digits=6&period=30"
            fi
        fi

        if [[ -z "$name" || -z "$url" ]]; then
            __log "missing name or url parameters." -t error -l otp
            return 1
        fi

        local secret="" type=""
        if [[ "$url" =~ otpauth://([^/]+)/ ]]; then type="${BASH_REMATCH[1],,}"; fi
        if [[ "$url" =~ secret=([^&]+) ]]; then secret="${BASH_REMATCH[1]}"; fi

        if [[ -z "$secret" || -z "$type" ]]; then
            __log "invalid otpauth URL. Could not extract secret or type." -t error -l otp
            return 1
        fi

        if grep -q "^$name:" "$__OTP_FILE" 2>/dev/null; then
            __log "entry '$name' already exists." -t error -l otp
            return 1
        fi

        echo "$name:$type:$secret" >> "$__OTP_FILE"
        __log "added entry '$name'." -t success -l otp
    }

    otp.rm() {
        local name="" positional=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --name) name="$2"; shift 2 ;;
                -*) __log "unknown option for 'rm': $1" -t error -l otp; return 1 ;;
                *) positional+=("$1"); shift ;;
            esac
        done

        [[ -z "$name" && ${#positional[@]} -ge 1 ]] && name="${positional[0]}"

        if [[ -z "$name" ]]; then
            __log "missing name parameter." -t error -l otp
            return 1
        fi

        if ! grep -q "^$name:" "$__OTP_FILE" 2>/dev/null; then
            __log "no entry found for '$name'." -t error -l otp
            return 1
        fi

        sed -i "/^$name:/d" "$__OTP_FILE"
        __log "removed '$name'." -t success -l otp
    }

    otp.list() {
        __log "Registered OTP entries:" -t info -l otp
        if [[ -s "$__OTP_FILE" ]]; then
            while IFS=: read -r entry_name _ _; do
                [[ -n "$entry_name" ]] && echo "- $entry_name"
            done < "$__OTP_FILE"
        else
            echo "(none)"
        fi
    }

    otp.all() {
        __log "Current OTP codes:" -t info -l otp
        while IFS=: read -r entry_name type secret; do
            [[ -z "$entry_name" ]] && continue
            if [[ "$type" == "totp" ]]; then
                echo "- $entry_name (TOTP): $(oathtool --totp -b "$secret")"
            elif [[ "$type" == "hotp" ]]; then
                __log "cannot generate HOTP for '$entry_name'. Requires a counter." -t warning -l otp
            fi
        done < "$__OTP_FILE"
    }

    otp.get() {
        local target="$1"
        local entry=$(grep "^$target:" "$__OTP_FILE" 2>/dev/null || true)
        if [[ -z "$entry" ]]; then
            __log "no entry found for '$target'." -t error -l otp
            return 1
        fi

        local name type secret
        IFS=: read -r name type secret <<< "$entry"

        if [[ "$type" == "totp" ]]; then
            local otp_code=$(oathtool --totp -b "$secret")
            if command -v xclip &> /dev/null; then
                echo -n "$otp_code" | xclip -selection clipboard
                __log "OTP for '$name' copied to clipboard." -t success -l otp
            else
                echo "$otp_code"
            fi
        elif [[ "$type" == "hotp" ]]; then
            __log "cannot generate HOTP for '$name'. Requires a counter." -t error -l otp
            return 1
        fi
    }

    otp() {
        local file="" secrets_from_cli=0 args=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --help|-h) otp.__help__; return 0 ;;
                --file) 
                    if [[ $# -lt 2 ]]; then
                        __log "--file requires a path argument." -t error -l otp
                        return 1
                    fi
                    file="$2"
                    secrets_from_cli=1
                    shift 2 
                    ;;
                *) args+=("$1"); shift ;;
            esac
        done

        if (( secrets_from_cli )); then
            if [[ ! -e "$file" ]]; then
                mkdir -p "$(dirname "$file")" 2>/dev/null || { __log "cannot create directory for '$file'." -t error -l otp; return 1; }
                touch "$file" 2>/dev/null || { __log "cannot create file '$file'." -t error -l otp; return 1; }
            fi
        else
            file="${OTP_SECRETS_FILE:-}"
            if [[ -z "$file" ]]; then
                __log "secrets file not specified (use --file or OTP_SECRETS_FILE)" -t error -l otp
                return 1
            fi
            if [[ ! -f "$file" ]]; then
                __log "secrets file '$file' does not exist." -t error -l otp
                return 1
            fi
        fi

        export __OTP_FILE="$file"

        if ! command -v oathtool &> /dev/null; then
            __log "missing oathtool (try: sudo apt-get install oathtool)" -t error -l otp
            return 1
        fi

        local sub="${args[0]:-}"
        local sub_args=("${args[@]:1}")

        case "$sub" in
            new)  otp.new "${sub_args[@]}" ;;
            rm)   otp.rm "${sub_args[@]}" ;;
            list) otp.list "${sub_args[@]}" ;;
            "")   otp.all ;;
            *)    otp.get "$sub" ;;
        esac
    }

    otp.__compl__() {
        local cur="${COMP_WORDS[COMP_CWORD]}" prev="${COMP_WORDS[COMP_CWORD-1]}"
        local file_path="${OTP_SECRETS_FILE:-}"

        for (( i=1; i<COMP_CWORD; i++ )); do
            if [[ "${COMP_WORDS[i]}" == "--file" ]]; then
                file_path="${COMP_WORDS[i+1]:-}"
            fi
        done

        if [[ "$prev" == "--file" ]]; then
            COMPREPLY=( $(compgen -f -- "$cur") )
            return 0
        fi

        local names=""
        if [[ -f "$file_path" ]]; then
            names=$(cut -d':' -f1 "$file_path" 2>/dev/null)
        fi

        local base_cmd=""
        for (( i=1; i<COMP_CWORD; i++ )); do
            local w="${COMP_WORDS[i]}"
            if [[ "$w" != -* && "$w" != "$file_path" ]]; then
                base_cmd="$w"
                break
            fi
        done

        if [[ -z "$base_cmd" ]]; then
            COMPREPLY=( $(compgen -W "new rm list --file $names" -- "$cur") )
            return 0
        fi

        case "$base_cmd" in
            new) COMPREPLY=( $(compgen -W "--name --url --service --user --secret --file" -- "$cur") ) ;;
            rm)  COMPREPLY=( $(compgen -W "--name --file $names" -- "$cur") ) ;;
            *)   COMPREPLY=( $(compgen -W "--file $names" -- "$cur") ) ;;
        esac
    }

    otp.__init__() {
        __compl otp
    }
}
