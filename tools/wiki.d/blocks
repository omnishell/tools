        html+="        <slides id=\"block-carousel-slides-${c_id}\" class=\"block-carousel-slides\">"$'\n'
        
        local i=1 it clean_it display_style
        for it in "${items[@]}"; do
            clean_it="${it//\"/}"
            clean_it="${clean_it//\'/}"
            clean_it="${clean_it%%,*}"
            clean_it="${clean_it#"${clean_it%%[![:space:]]*}"}"
            clean_it="${clean_it%"${clean_it##*[![:space:]]}"}"
            display_style=""
            [[ $i -gt $c_items ]] && display_style=" style=\"display: none;\""
            
            html+="            <slide id=\"block-carousel-slide-${i}-${c_id}\" class=\"block-carousel-slide\"${display_style}>"$'\n'
            if [[ -n "${child_html[$clean_it]:-}" ]]; then
                html+="${child_html[$clean_it]}"
            fi
            html+="            </slide>"$'\n'
            ((i++))
        done
        html+="        </slides>"$'\n'
        html+="        <button class=\"carousel-btn-next\">Next</button>"$'\n'
        html+="    </div>"$'\n'
        html+="    <nav class=\"carousel-dots\">"$'\n'
        local j active_class dots_count
        dots_count=$(( (${#items[@]} + c_items - 1) / c_items ))
        for ((j=0; j<dots_count; j++)); do
            active_class=""
            [[ $j -eq 0 ]] && active_class=" active"
            html+="        <button class=\"carousel-dot${active_class}\" data-index=\"${j}\"></button>"$'\n'
        done
        html+="    </nav>"$'\n'
        html+="</carousel>"$'\n'
        content+="${html}"
    }   

    __block_grid() {
        local bname="$1"
        local _ref="$2[@]"
        local -a my_buffer=("${!_ref}")
        if [[ ${#my_buffer[@]} -eq 0 ]]; then return; fi
        local g_id="rnd-$RANDOM"
        local g_gap="" b_width="" b_style=""
        local -a grid_rows=()
        local -A grid_child_html=()
        local grid_in_child="" grid_child_name="" grid_child_indent=""
        local -a grid_child_buffer=()
        local current_key="" current_val="" b_line
        
        for b_line in "${my_buffer[@]}"; do
            if [[ -n "$grid_in_child" ]]; then
                if [[ "$b_line" =~ ^([[:space:]]*)\{\{[[:space:]]*block\.end[[:space:]]*\}\}[[:space:]]*$ ]] && [[ "${BASH_REMATCH[1]}" == "$grid_child_indent" ]]; then
                    local c_id="" c_line
                    for c_line in "${grid_child_buffer[@]}"; do
                        if [[ "$c_line" =~ ^[[:space:]]*::[[:space:]]*__id__[[:space:]]*:[[:space:]]*(.*)$ ]]; then
                            c_id="${BASH_REMATCH[1]}"
                            c_id="${c_id#"${c_id%%[![:space:]]*}"}"; c_id="${c_id%"${c_id##*[![:space:]]}"}"
                            break
                        fi
                    done
                    if [[ -n "$current_key" ]]; then
                        current_val="${current_val#"${current_val%%[!$'\n\r']*}"}"
                        current_val="${current_val%"${current_val##*[![:space:]]}"}"
                        if [[ "$current_key" == "__id__" ]]; then g_id="$current_val"
                        elif [[ "$current_key" == "gap" ]]; then g_gap="$current_val"
                        elif [[ "$current_key" == "row" ]]; then grid_rows+=("$current_val")
                        elif [[ "$current_key" == "__width__" ]]; then b_width="$current_val"
                        elif [[ "$current_key" == "__style__" ]]; then b_style="$current_val"; fi
                        current_key=""
                    fi
                    local old_content="$content"
                    content=""
                    if declare -F "__block_${grid_child_name}" >/dev/null; then
                        "__block_${grid_child_name}" "$grid_child_name" grid_child_buffer
                    else
                        __block_core "$grid_child_name" grid_child_buffer
                    fi
                    if [[ -n "$c_id" ]]; then
                        grid_child_html["$c_id"]="$content"
                    fi
                    content="$old_content"
                    grid_in_child=""
                else
                    grid_child_buffer+=("$b_line")
                fi
                continue
            fi
            
            if [[ "$b_line" =~ ^([[:space:]]*)\{\{[[:space:]]*block\.([a-zA-Z0-9_-]+)[[:space:]]*\}\}[[:space:]]*$ ]]; then
                grid_in_child="1"
                grid_child_indent="${BASH_REMATCH[1]}"
                grid_child_name="${BASH_REMATCH[2]}"
                grid_child_buffer=()
                if [[ -n "$current_key" ]]; then
                    current_val="${current_val#"${current_val%%[!$'\n\r']*}"}"
                    current_val="${current_val%"${current_val##*[![:space:]]}"}"
                    if [[ "$current_key" == "__id__" ]]; then g_id="$current_val"
                    elif [[ "$current_key" == "gap" ]]; then g_gap="$current_val"
                    elif [[ "$current_key" == "row" ]]; then grid_rows+=("$current_val")
                    elif [[ "$current_key" == "__width__" ]]; then b_width="$current_val"
                    elif [[ "$current_key" == "__style__" ]]; then b_style="$current_val"; fi
                    current_key=""
                fi
                continue
            fi
            
            if [[ "$b_line" =~ ^[[:space:]]*::[[:space:]]*([a-zA-Z0-9_-]+):[[:space:]]*(.*)$ ]]; then
                if [[ -n "$current_key" ]]; then
                    current_val="${current_val#"${current_val%%[!$'\n\r']*}"}"
                    current_val="${current_val%"${current_val##*[![:space:]]}"}"
                    if [[ "$current_key" == "__id__" ]]; then g_id="$current_val"
                    elif [[ "$current_key" == "gap" ]]; then g_gap="$current_val"
                    elif [[ "$current_key" == "row" ]]; then grid_rows+=("$current_val")
                    elif [[ "$current_key" == "__width__" ]]; then b_width="$current_val"
                    elif [[ "$current_key" == "__style__" ]]; then b_style="$current_val"; fi
                fi
                current_key="${BASH_REMATCH[1]}"
                current_val="${BASH_REMATCH[2]}"
                current_val="${current_val#"${current_val%%[![:space:]]*}"}"
                current_val="${current_val%"${current_val##*[![:space:]]}"}"
            else
                if [[ -n "$current_key" ]]; then
                    current_val+=$'\n'"$b_line"
                fi
            fi
        done
        
        if [[ -n "$current_key" ]]; then
            current_val="${current_val#"${current_val%%[!$'\n\r']*}"}"
            current_val="${current_val%"${current_val##*[![:space:]]}"}"
            if [[ "$current_key" == "__id__" ]]; then g_id="$current_val"
            elif [[ "$current_key" == "gap" ]]; then g_gap="$current_val"
            elif [[ "$current_key" == "row" ]]; then grid_rows+=("$current_val")
            elif [[ "$current_key" == "__width__" ]]; then b_width="$current_val"
            elif [[ "$current_key" == "__style__" ]]; then b_style="$current_val"; fi
        fi
        
        local rows_style=""
        if [[ -n "$g_gap" ]]; then
            if [[ "$g_gap" =~ ^[0-9]+$ ]]; then g_gap="${g_gap}px"; fi
            rows_style=" style=\"gap: ${g_gap};\""
        fi
        
        local style_attr="$(__get_style_attr "$b_width" "$b_style")"
        local html="<grid id=\"block-grid-${g_id}\" class=\"block-grid\"${style_attr}>"$'\n'
        html+="    <rows id=\"block-grid-rows-${g_id}\" class=\"block-grid-rows\"${rows_style}>"$'\n'
        
        local r r_id r_pos class_attr inline_child_style
        for r in "${grid_rows[@]}"; do
            r_id=""
            r_pos=""
            if [[ "$r" == *"="* ]]; then
                local prev_IFS="$IFS"
                IFS=','
                local tokens=($r)
                IFS="$prev_IFS"
                local token
                for token in "${tokens[@]}"; do
                    token="${token#"${token%%[![:space:]]*}"}"
                    token="${token%"${token##*[![:space:]]}"}"
                    if [[ "$token" == id=* ]]; then
                        r_id="${token#id=}"
                    elif [[ "$token" == pos=* ]]; then
                        r_pos="${token#pos=}"
                    fi
                done
            else
                r_id="$r"
            fi
            
            r_id="${r_id//\"/}"
            r_id="${r_id//\'/}"
            r_id="${r_id#"${r_id%%[![:space:]]*}"}"
            r_id="${r_id%"${r_id##*[![:space:]]}"}"
            
            r_pos="${r_pos//\"/}"
            r_pos="${r_pos//\'/}"
            r_pos="${r_pos#"${r_pos%%[![:space:]]*}"}"
            r_pos="${r_pos%"${r_pos##*[![:space:]]}"}"
            
            class_attr="block-grid-row"
            inline_child_style=""
            
            if [[ -n "$r_pos" ]]; then
                class_attr+=" pos-${r_pos}"
                if [[ "$r_pos" == "center" ]]; then inline_child_style=" style=\"display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center;\""
                elif [[ "$r_pos" == "left" ]]; then inline_child_style=" style=\"display: flex; flex-direction: column; justify-content: flex-start; align-items: flex-start; text-align: left;\""
                elif [[ "$r_pos" == "right" ]]; then inline_child_style=" style=\"display: flex; flex-direction: column; justify-content: flex-end; align-items: flex-end; text-align: right;\""
                fi
            fi
            
            local child_content="${grid_child_html[$r_id]:-}"
            local target_tag="<row id=\"block-row-${r_id}\" class=\"block-row\">"
            
            if [[ "$child_content" == *"$target_tag"* ]]; then
                local new_tag="<row id=\"block-grid-row-${r_id}\" class=\"block-row ${class_attr}\" data-pos=\"${r_pos}\"${inline_child_style}>"
                html+="${child_content/$target_tag/$new_tag}"
            else
                html+="        <row id=\"block-grid-row-${r_id}\" class=\"${class_attr}\" data-pos=\"${r_pos}\"${inline_child_style}>"$'\n'
                html+="${child_content}"
                html+="        </row>"$'\n'
            fi
        done
        html+="    </rows>"$'\n'
        html+="</grid>"$'\n'
        content+="${html}"
    }    
