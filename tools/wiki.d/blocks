                fi
                continue
            fi
            
            if [[ "$b_line" =~ ^[[:space:]]*::[[:space:]]*end[[:space:]]*: ]]; then
                if [[ -n "$current_key" ]]; then
                    current_val="${current_val#"${current_val%%[!$'\n\r']*}"}"
                    current_val="${current_val%"${current_val##*[![:space:]]}"}"
                    if [[ "$current_key" == "__id__" ]]; then t_id="$current_val"
                    elif [[ "$current_key" == "text" ]]; then t_text="$current_val"
                    elif [[ "$current_key" == "__width__" ]]; then b_width="$current_val"
                    elif [[ "$current_key" == "__style__" ]]; then b_style="$current_val"; fi
                    current_key=""
                fi
                continue
            fi
            
            if [[ "$b_line" =~ ^[[:space:]]*::[[:space:]]*([a-zA-Z0-9_-]+):[[:space:]]*(.*)$ ]]; then
                if [[ -n "$current_key" ]]; then
                    current_val="${current_val#"${current_val%%[!$'\n\r']*}"}"
                    current_val="${current_val%"${current_val##*[![:space:]]}"}"
                    if [[ "$current_key" == "__id__" ]]; then t_id="$current_val"
                    elif [[ "$current_key" == "text" ]]; then t_text="$current_val"
                    elif [[ "$current_key" == "__width__" ]]; then b_width="$current_val"
                    elif [[ "$current_key" == "__style__" ]]; then b_style="$current_val"; fi
                fi
                current_key="${BASH_REMATCH[1]}"
                current_val="${BASH_REMATCH[2]}"
                current_val="${current_val#"${current_val%%[![:space:]]*}"}"
                current_val="${current_val%"${current_val##*[![:space:]]}"}"
            else
                if [[ -n "$current_key" ]]; then
                    current_val+=$'\n'"$b_line"
                fi
            fi
        done
