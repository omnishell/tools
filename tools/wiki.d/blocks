                    [[ -z "$c_id" ]] && c_id="child-${#child_order[@]}-$RANDOM"
                    child_html["$c_id"]="$content"
                    child_order+=("$c_id")
                    content="$old_content"
                    in_child=""
                else
                    child_buffer+=("$b_line")
                fi
                continue
            fi
            
            if [[ "$b_line" =~ ^([[:space:]]*)\{\{[[:space:]]*block\.([a-zA-Z0-9_-]+)[[:space:]]*\}\}[[:space:]]*$ ]]; then
                in_child="1"
