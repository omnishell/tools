#! /bin/bash
__build__() {
    __build_init() {
        if [[ -z "${WIKI_PAGES[$w_name]:-}" ]]; then
            __log "WIKI_PAGES empty for '$w_name'. Building dynamically from '$SOURCEDIR'." -t info -l wiki
            while IFS= read -r -d '' file; do
                local rel_path="${file#$SOURCEDIR/}"
                local no_ext="${rel_path%.md}"
                local slug="${no_ext//\//.}"
                _pages+=("$slug")
                WIKI_PAGE_VARS["${w_name}::${slug}"]="path:${file}"
            done < <(find "$SOURCEDIR" -type f -name "*.md" -print0)
        else
            local OIFS="$IFS"; IFS=','
            local p
            for p in ${WIKI_PAGES[$w_name]}; do _pages+=("$p"); done
            IFS="$OIFS"
        fi
        local p
        for p in "${_pages[@]}"; do
            local p_vars="${WIKI_PAGE_VARS[${w_name}::${p}]:-}"
            local file="${p_vars##*path:}"
            file="${file%%,*}"
            local fm_title="" fm_weight="0"
            if [[ -f "$file" ]]; then
                fm_title="$(__fm_val "$file" "title" || true)"
                fm_weight="$(__fm_val "$file" "weight" || true)"
                [[ -z "$fm_weight" ]] && fm_weight="0"
            fi
            PAGE_TITLES["$p"]="$fm_title"
            PAGE_WEIGHTS["$p"]="$fm_weight"
            
            local -a parts=()
            local OIFS="$IFS"; IFS='.'; read -ra parts <<< "$p"; IFS="$OIFS"
            if [ "${#parts[@]}" -ge 2 ]; then _nested_pages+=("$p")
            else _global_pages+=("${parts[0]}"); fi
        done
    }

    __build_cache() {
        mkdir -p "$cache_dir" 2>/dev/null
        local tmpl_hash=""
        if [[ -d "$TEMPLATEDIR" ]]; then
            tmpl_hash=$(find "$TEMPLATEDIR" -type f -exec cksum {} + | cksum | awk '{print $1 "_" $2}')
        fi
        local old_tmpl_hash=""
        [[ -f "$tmpl_cache_file" ]] && old_tmpl_hash=$(cat "$tmpl_cache_file")
        if [[ "$tmpl_hash" != "$old_tmpl_hash" ]]; then
            force_rebuild=1
            echo "$tmpl_hash" > "$tmpl_cache_file"
            > "$cache_file"
        fi
        if [[ -z "$p_name" && $force_rebuild -eq 1 ]]; then
            __log "Cleaning and preparing environment for '$w_name'..." -t info -l wiki
            find "$BUILDDIR" -mindepth 1 -maxdepth 1 ! -name "$(basename "$cache_dir")" -exec rm -rf {} + 2>/dev/null || true
        fi
        
        mkdir -p "$BUILDDIR/_static"
        if [ -d "$STATICDIR" ]; then cp -r "$STATICDIR"/* "$BUILDDIR/_static/" 2>/dev/null || true; fi
        if [[ -f "$cache_file" ]]; then
            while read -r h f; do
                [[ -n "$f" ]] && CACHE_HASHES["$f"]="$h"
            done < "$cache_file"
        fi
    }
    __build_partials() {
        __partial_menu
        __partial_sidebar
        
        for p in "${_pages[@]}"; do
            local map_p_name="${p##*.}" map_p_dir="" map_p_url=""
            local disp_name="${PAGE_TITLES[$p]:-}"
            [[ -z "$disp_name" ]] && disp_name="$map_p_name"
            if [[ "$p" == *.* ]]; then
                local p_dir_raw="${p%.*}"
                map_p_dir="${p_dir_raw//./\/}"; map_p_url="${map_p_dir}/${map_p_name}.html"
            else
                map_p_dir="."; map_p_url="${map_p_name}.html"
            fi
            DIR_FILES_MAP["$map_p_dir"]+="<li><a href=\"/${map_p_url}\">${disp_name}</a></li>"$'\n'
        done
    }

    __build_main() {
        if [[ -n "$p_name" ]]; then build_targets=("$p_name")
        else build_targets=("${_pages[@]}"); fi
        for p in "${build_targets[@]}"; do
            local p_vars="${WIKI_PAGE_VARS[${w_name}::${p}]:-}"
            local file="" p_tmpl=""
            local OIFS="$IFS"; IFS=','
            for pair in $p_vars; do
                local k="${pair%%:*}" v="${pair#*:}"
                case "$k" in
                    path) file="$v" ;;
                    template) p_tmpl="$v" ;;
                esac
            done
            IFS="$OIFS"
            if [[ ! -f "$file" ]]; then continue; fi
            local in_globals=0 g_line
            while IFS= read -r g_line || [[ -n "$g_line" ]]; do
                g_line="${g_line%$'\r'}"
                if (( in_globals == 0 )); then
                    [[ "$g_line" =~ ^[[:space:]]*\{\{[[:space:]]*block\.globals[[:space:]]*\}\}[[:space:]]*$ ]] && in_globals=1
                else
                    [[ "$g_line" =~ ^[[:space:]]*\{\{[[:space:]]*block\.end[[:space:]]*\}\}[[:space:]]*$ ]] && break
                    if [[ "$g_line" =~ ^[[:space:]]*::[[:space:]]*template:[[:space:]]*(.*)$ ]]; then
                        local temp_tmpl="${BASH_REMATCH[1]}"
                        temp_tmpl="${temp_tmpl#"${temp_tmpl%%[![:space:]]*}"}"
                        temp_tmpl="${temp_tmpl%"${temp_tmpl##*[![:space:]]}"}"
                        [[ -n "$temp_tmpl" ]] && p_tmpl="${TEMPLATEDIR}/${temp_tmpl}"
                    fi
                fi
            done < "$file"
            local page_tmpl_raw="${p_tmpl:-$TEMPLATEDIR}"
            if [[ -n "${WIKI_TEMPLATE_VARS[$page_tmpl_raw]:-}" ]]; then
                page_tmpl_raw="${WIKI_TEMPLATE_VARS[$page_tmpl_raw]}"
            elif [[ -d "$page_tmpl_raw" ]]; then
                page_tmpl_raw="${page_tmpl_raw}/layout.html"
            fi
            
            if [[ ! -f "$page_tmpl_raw" ]]; then
                __log "Template file missing for page $p at $page_tmpl_raw" -t error -l wiki
                continue
            fi
            local pagename="$p"
            local out_path="$BUILDDIR/${p//./\/}.html"
            local current_dir="${p%.*}"
            if [[ "$current_dir" == "$p" ]]; then current_dir="."; fi
            mkdir -p "${out_path%/*}"
            local file_hash=$(cksum "$file" | awk '{print $1 "_" $2}')
            if [[ $force_rebuild -eq 0 && "${CACHE_HASHES[$file]:-}" == "$file_hash" && -f "$out_path" ]]; then
                for idx_f in "$cache_dir"/${pagename}_index_*.json; do
                    [[ -f "$idx_f" ]] || continue
                    local bname="${idx_f##*_index_}"
                    bname="${bname%.json}"
                    SEARCH_INDEX_MAP["$bname"]+=$(cat "$idx_f")
                done
                __log "Skipped rendering $pagename (unmodified)" -t info -l wiki
                continue
            fi
            
            local RAW_LAYOUT
            read -r -d '' RAW_LAYOUT < "$page_tmpl_raw" || true
            local -a layout_lines
            mapfile -t layout_lines <<< "$RAW_LAYOUT"
            
            local -A old_len_map=()
            for k in "${!SEARCH_INDEX_MAP[@]}"; do old_len_map["$k"]="${#SEARCH_INDEX_MAP[$k]}"; done
            
            __render_main "$file" "$pagename" "$out_path" "$current_dir"
            
            for k in "${!SEARCH_INDEX_MAP[@]}"; do
                local old_len="${old_len_map[$k]:-0}"
                local new_content="${SEARCH_INDEX_MAP[$k]:$old_len}"
                if [[ -n "$new_content" ]]; then
                    printf "%s" "$new_content" > "$cache_dir/${pagename}_index_${k}.json"
                fi
            done
            CACHE_HASHES["$file"]="$file_hash"
        done

        local search_js="const SEARCH_CONFIG = ["
        local sf=1
        for k in "${!SEARCH_INDEX_MAP[@]}"; do
            (( sf == 0 )) && search_js+=","
            local fallback="${k^}"
            local tkey="${BLOCK_TITLE_KEYS[$k]:-$k}"
            [[ "$k" == "page" ]] && tkey="pagename"
            [[ "$k" == "table" ]] && tkey="caption"
            search_js+=" { id: '$k', others: ['${k}s'], titleKey: '$tkey', fallback: '$fallback' }"
            sf=0
        done
        search_js+=" ];"

        for p in "${build_targets[@]}"; do
            local out_path="$BUILDDIR/${p//./\/}.html"
            if [[ -f "$out_path" ]]; then
                local html_content
                html_content="$(<"$out_path")"
                if [[ "$html_content" == *"%%WIKI_SEARCH_CONFIG%%"* ]]; then
                    html_content="${html_content//%%WIKI_SEARCH_CONFIG%%/$search_js}"
                    printf "%s" "$html_content" > "$out_path"
                elif [[ "$html_content" == *"const SEARCH_CONFIG = ["* ]]; then
                    local pre="${html_content%%const SEARCH_CONFIG = \[*}"
                    local post="${html_content#*const SEARCH_CONFIG = \[}"
                    post="${post#*\];}"
                    html_content="${pre}${search_js}${post}"
                    printf "%s" "$html_content" > "$out_path"
                fi
            fi
        done
    }

    __build_index() {
        > "$cache_file"
        for f in "${!CACHE_HASHES[@]}"; do
            echo "${CACHE_HASHES[$f]} $f" >> "$cache_file"
        done
        __save
        
        local json_content="{"
        local first=1
        for k in "${!SEARCH_INDEX_MAP[@]}"; do
            local arr_str="${SEARCH_INDEX_MAP[$k]}"
            arr_str="${arr_str%$'\n'}"
            arr_str="${arr_str%,}"
            (( first == 0 )) && json_content+=","
            json_content+="\"$k\": [ $arr_str ]"
            first=0
        done
        json_content+="}"
        printf "%s" "$json_content" > "$BUILDDIR/index.json"
    }
}
