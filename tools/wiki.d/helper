#! /bin/bash

__helper__() {

    declare -gA WIKIS WIKI_VARS WIKI_PAGES WIKI_PAGE_VARS WIKI_TEMPLATES WIKI_TEMPLATE_VARS WIKI_TOPICS WIKI_REFS WIKI_BLOCKS 2>/dev/null || true
        
    __slugify() {
        local s="${1,,}"
        s="${s// /-}"
        s="${s// /a}"; s="${s// /a}"; s="${s// /a}"; s="${s// /a}"; s="${s// /a}"
        s="${s// /e}"; s="${s// /e}"; s="${s// /e}"; s="${s// /e}"
        s="${s// /i}"; s="${s// /i}"; s="${s// /i}"; s="${s// /i}"
        s="${s// /o}"; s="${s// /o}"; s="${s// /o}"; s="${s// /o}"; s="${s// /o}"
        s="${s// /u}"; s="${s// /u}"; s="${s// /u}"; s="${s// /u}"
        s="${s// /c}"; s="${s// /n}"
        s="${s//[^a-z0-9_.-]/}"
        echo "$s"
    }

    __json_escape() {
        local s="$1"
        s="${s//\\/\\\\}"
        s="${s//\"/\\\"}"
        s="${s//$'\n'/\\n}"
        s="${s//$'\r'/}"
        s="${s//$'\t'/\\t}"
        printf "%s" "$s"
    }    
        
    __serialize_assoc() {
        local arr_name="$1" key val
        local -n arr="$arr_name"
        echo -n "declare -A ${arr_name}=("
        for key in "${!arr[@]}"; do
            val="${arr[$key]}"
            echo -n "[\"$key\"]=\"${val//\"/\\\"}\" "
        done
        echo ")"
    }
    
    __save() {
        local rcfile="${OMNIRC:-$HOME/.omnirc}"
        local tmp_content="" line
        declare -p WIKIS >/dev/null 2>&1 || declare -g -a WIKIS=()
        declare -p WIKI_VARS >/dev/null 2>&1 || declare -g -A WIKI_VARS=()
        declare -p WIKI_PAGES >/dev/null 2>&1 || declare -g -A WIKI_PAGES=()
        declare -p WIKI_PAGE_VARS >/dev/null 2>&1 || declare -g -A WIKI_PAGE_VARS=()
        declare -p WIKI_TEMPLATES >/dev/null 2>&1 || declare -g -a WIKI_TEMPLATES=()
        declare -p WIKI_TEMPLATE_VARS >/dev/null 2>&1 || declare -g -A WIKI_TEMPLATE_VARS=()
        declare -p WIKI_TOPICS >/dev/null 2>&1 || declare -g -A WIKI_TOPICS=()
        declare -p WIKI_REFS >/dev/null 2>&1 || declare -g -A WIKI_REFS=()
        declare -p WIKI_BLOCKS >/dev/null 2>&1 || declare -g -A WIKI_BLOCKS=()
        if [[ -f "$rcfile" ]]; then
            while IFS= read -r line || [[ -n "$line" ]]; do
                if [[ "$line" == "declare -a WIKIS="* || \
                      "$line" == "declare -A WIKI_VARS="* || \
                      "$line" == "declare -A WIKI_PAGES="* || \
                      "$line" == "declare -A WIKI_PAGE_VARS="* || \
                      "$line" == "declare -a WIKI_TEMPLATES="* || \
                      "$line" == "declare -A WIKI_TEMPLATE_VARS="* || \
                      "$line" == "declare -A WIKI_TOPICS="* || \
                      "$line" == "declare -A WIKI_REFS="* || \
                      "$line" == "declare -A WIKI_BLOCKS="* ]]; then
                    continue
                fi
                tmp_content+="$line"$'\n'
            done < "$rcfile"
        fi
        local wikis_str="" w
        for w in "${WIKIS[@]}"; do wikis_str+="\"$w\" "; done
        tmp_content+="declare -a WIKIS=($wikis_str)"$'\n'
        tmp_content+="$(__serialize_assoc WIKI_VARS)"$'\n'
        tmp_content+="$(__serialize_assoc WIKI_PAGES)"$'\n'
        tmp_content+="$(__serialize_assoc WIKI_PAGE_VARS)"$'\n'
        local tmpls_str="" t
        for t in "${WIKI_TEMPLATES[@]}"; do tmpls_str+="\"$t\" "; done
        tmp_content+="declare -a WIKI_TEMPLATES=($tmpls_str)"$'\n'
        tmp_content+="$(__serialize_assoc WIKI_TEMPLATE_VARS)"$'\n'
        tmp_content+="$(__serialize_assoc WIKI_TOPICS)"$'\n'
        tmp_content+="$(__serialize_assoc WIKI_REFS)"$'\n'
        tmp_content+="$(__serialize_assoc WIKI_BLOCKS)"$'\n'
        printf "%s" "$tmp_content" > "$rcfile"
    }
 

    __search_index() {
        local plain_content=""
        local rem="$content"
        while [[ "$rem" == *"<"*">"* ]]; do
            plain_content+="${rem%%<*}"
            rem="${rem#*>}"
        done
        plain_content+="$rem"
        local enc_url="$(__json_escape "/${pagename//./\/}.html")"
        local enc_pagename="$(__json_escape "$pagename")"
        local enc_category="$(__json_escape "$current_dir")"
        local enc_content="$(__json_escape "$plain_content")"
        SEARCH_INDEX_MAP["page"]+="{\"url\":\"$enc_url\",\"pagename\":\"$enc_pagename\",\"category\":\"$enc_category\",\"content\":\"$enc_content\"},"$'\n'
    }
}
